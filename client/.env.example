# Supabase connection for the browser client.
# Copy this file to .env.local (git-ignored) and fill in your project values.
# Project URL: Supabase dashboard > Project Settings > Data API (or API).
# Publishable key: Project Settings > API Keys (the sb_publishable_... key).
# Do NOT use the sb_secret_... key here - it bypasses RLS and must stay server-side.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Base URL of the FastAPI AI service (backend/). Defaults to localhost:8000.
VITE_API_URL=http://localhost:8000
